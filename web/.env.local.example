# Optional: point the web app at the real Python backend.
# If both values are empty, the frontend falls back to local research fixtures.
INKDESK_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional: timeout used by `npm run e2e:fullstack` while waiting for the backend.
INKDESK_E2E_BACKEND_TIMEOUT_MS=60000
