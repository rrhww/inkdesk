POSTGRES_DB=inkvault
POSTGRES_USER=inkvault
POSTGRES_PASSWORD=inkvault
POSTGRES_PORT=15432

MINIO_ROOT_USER=inkvault
MINIO_ROOT_PASSWORD=inkvaultminio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

INKVAULT_SERVER_PORT=8080
INKVAULT_WEB_PORT=3000
INKVAULT_ENV=local
INKVAULT_AUTH_SECRET=replace-with-a-long-random-secret
INKVAULT_AUTH_SESSION_DURATION=PT8H
INKVAULT_AUTH_ALLOW_LEGACY_OWNER_COOKIE=true
INKVAULT_AGENT_RUNTIME=langgraph
INKVAULT_AGENT_PROVIDER_PROFILE=openai
INKVAULT_AGENT_MODEL=gpt-4.1-mini
INKVAULT_AGENT_API_KEY=
INKVAULT_AGENT_BASE_URL=
INKVAULT_AGENT_CONNECT_TIMEOUT_SECONDS=2
INKVAULT_AGENT_READ_TIMEOUT_SECONDS=20
INKVAULT_EMBEDDING_PROVIDER_PROFILE=openai
INKVAULT_EMBEDDING_MODEL=text-embedding-3-small
INKVAULT_EMBEDDING_API_KEY=
INKVAULT_EMBEDDING_BASE_URL=
INKVAULT_ENABLE_WEB_ASSIST=true
INKVAULT_ENABLE_LOCAL_SEED=true
OPENAI_API_KEY=
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
